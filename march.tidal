  # room 0.3
  # djf 0.45
  -- # octave 6
  # gain (range 1.15 0.85 sine) # speed "1.5 1.6 1.2"
  -- # gain 0.7

do
d1 $ qt $ striate 2 . randslice 12 $ sound "kingston" # cut 1
    # gain 1.5 # djf 0.8 # lpf 1800

d7 $ qt $ chop 4 $ loopAt 8 $ sound "dub"
  # gain 1.15 # djf 0.4 # room 0.2

d4
  $ fast 2 $ every 2 (striate 2 . jux rev)
  $ sound "house:6(7,8)" # pan "1 1.2 2 0.5"
  # gain "1.05"
  -- # djf 0.25


d7 silence

hush


