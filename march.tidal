setcps 0.6

-- setcps (130/60/4)

hush

-- shoutout to that chaotic breakfast in Kingston, JA

do
d1 $ jux rev $ slice 4 "1 3 4 2" $ sound "kingston" # cut 1
  # gain 1.4

d1 silence

d5
-- $ sometimes (# octave 6) $ every 2 (striate 2)
$ sound "bsguitar:4*8" # pan "1 1.2 2 0.5"
# gain "1.15"

d13 $ someCycles (jux rev)
